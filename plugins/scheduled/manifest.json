{
  "manifest_version": 1,
  "id": "scheduled",
  "name": "Scheduled Jobs",
  "version": "0.1.0",
  "description": "Unified view of cron + launchd jobs the user has installed.",
  "engines": { "claude-instances": "^2.0.0" },
  "icon": "calendar.badge.clock",
  "exec": {
    "kind": "script",
    "fetch": "./fetch.sh"
  },
  "refresh": {
    "on_fs_change": ["~/Library/LaunchAgents"],
    "poll_seconds": 600
  },
  "limits": {
    "fetch_timeout_ms": 5000
  },
  "contributes": {
    "dashboard.pane": [
      {
        "id": "scheduled-main",
        "title": "Scheduled",
        "subtitle": "Cron + launchd jobs",
        "section": "Tools",
        "icon": "calendar.badge.clock",
        "panes": [
          { "kind": "summary",  "source": "fetch:summary"  },
          { "kind": "schedule", "source": "fetch:schedule" }
        ]
      }
    ]
  }
}
