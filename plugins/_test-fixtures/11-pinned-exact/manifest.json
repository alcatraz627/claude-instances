{
  "manifest_version": 1,
  "id": "exact-pin",
  "name": "Exact Pin",
  "version": "0.1.0",
  "engines": { "claude-instances": "2.0.0" },
  "exec": { "kind": "script", "fetch": "./fetch.sh" },
  "contributes": {
    "dashboard.pane": [
      { "id": "ep-main", "title": "EP",
        "panes": [{ "kind": "summary", "source": "fetch:s" }] }
    ]
  }
}
